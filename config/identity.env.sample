# tac-master: Bot Identity & Secrets
#
# Copy to config/identity.env and fill in actual values.
# chmod 600 config/identity.env — this file MUST NOT be world-readable.
# Never commit the real file; see .gitignore.

# ---- GitHub identity (krypto-agent bot account) ----
GITHUB_USER=krypto-agent
GITHUB_EMAIL=krypto-agent@users.noreply.github.com

# Fine-grained PAT with access ONLY to repos in config/repos.yaml allowlist.
# Required scopes:
#   - contents: read/write
#   - issues: read/write
#   - pull_requests: read/write
#   - workflows: read (to observe CI status)
#   - metadata: read
GITHUB_PAT=ghp_REPLACE_ME

# Webhook secret (shared with GitHub webhook config)
GITHUB_WEBHOOK_SECRET=REPLACE_ME

# ---- Anthropic ----
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
# Optional: override the claude binary path (defaults to `claude` in PATH)
# CLAUDE_CODE_PATH=/usr/local/bin/claude

# ---- Optional: Cloudflare R2 (for review screenshot uploads) ----
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_ENDPOINT=

# ---- Daemon behavior ----
TAC_MASTER_HOME=/srv/tac-master
TAC_MASTER_LOG_LEVEL=INFO
TAC_MASTER_POLL_INTERVAL=20
TAC_MASTER_MAX_CONCURRENT=15
