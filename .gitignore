# Secrets and local config — NEVER commit credentials or secret material
.env
.env.*
!.env.sample
config/identity.env
config/*.local.yaml

# User config files — only .sample templates are tracked in git.
# Copy *.sample → * and fill in your values; git pull will never overwrite them.
config/repos.yaml
config/budgets.yaml
config/policies.yaml
# Catch-all: any file with creds / secret / password / token in its name
*creds*
*secret*
*password*
*token*
!*token_tracker*               # Python source code exception
!*_token.py                     # Python source code exception
.tac-master-creds.env
.tac-master-creds.env.txt
.tac-master-creds.*
credentials.json
credentials.*
*.pem
*.key
*.p12
*.pfx
id_rsa*
id_ed25519*
id_ecdsa*
authorized_keys
known_hosts

# Runtime state and local clones
state/*.sqlite
state/*.sqlite-journal
state/*.sqlite-wal
state/*.sqlite-shm
repos/
trees/
logs/
agents/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Node/dashboard build artifacts
node_modules/
dist/
.vite/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# Claude Code session state
.claude/sessions/
