# Top-level .env.sample for local development / dev runs.
# For production deployment, use config/identity.env instead.

# Point at your local config
TAC_MASTER_HOME=.
TAC_MASTER_LOG_LEVEL=DEBUG
TAC_MASTER_POLL_INTERVAL=20
TAC_MASTER_MAX_CONCURRENT=3

# Bot identity (override in config/identity.env for production)
GITHUB_USER=krypto-agent
GITHUB_PAT=ghp_REPLACE_ME
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
